{
  "name": "scaffoldpro",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "functions:build": "npm --prefix functions run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "emulators:start": "npm run functions:build && firebase emulators:start --project demo-scaffoldpro --only auth,firestore,functions",
    "test:rules": "firebase emulators:exec --project demo-scaffoldpro --only firestore \"node --test tests/firestore/pm.rules.test.js\"",
    "test:e2e": "playwright test",
    "seed:pm": "node scripts/seed-pm-emulator.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "firebase": "^12.8.0",
    "lucide-react": "^0.460.0",
    "mapbox-gl": "^3.21.0",
    "polygon-clipping": "^0.15.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "three": "^0.170.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "firebase-tools": "^15.9.1",
    "globals": "^17.3.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.1"
  }
}
